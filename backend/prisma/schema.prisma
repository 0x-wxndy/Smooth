generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  LEARNER
  TEACHER
  CLIENT
  ADMIN
}

enum CourseCategory {
  SOFTWARE_DEV
  UI_UX
  GRAPHIC_DESIGN
  DIGITAL_MARKETING
  CYBERSECURITY
  AI
  LANGUAGES
  BUSINESS
  OTHER
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED
}

enum CourseSourceType {
  UPLOADED
  YOUTUBE
  EXTERNAL
}

enum BookingType {
  COURSE_SESSION
  MENTORING
  SERVICE
  CLASSROOM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  FREELANCE
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

enum ServiceStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ReviewTargetType {
  COURSE
  TEACHER
  SERVICE
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  role          UserRole  @default(LEARNER)
  displayName   String    @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  googleId      String?   @unique @map("google_id")
  emailVerified Boolean   @default(false) @map("email_verified")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  learnerProfile   LearnerProfile?
  teacherProfile   TeacherProfile?
  clientProfile    ClientProfile?
  wallet           GamificationWallet?
  enrollments      Enrollment[]
  reviews          Review[]
  followers        Follow[]           @relation("Following")
  following        Follow[]           @relation("Follower")
  courses          Course[]
  services         Service[]
  bookingsMade     Booking[]          @relation("BookingRequester")
  bookingsReceived Booking[]          @relation("BookingProvider")
  jobApplications  JobApplication[]
  aiUsageLogs      AiUsageLog[]
  achievements     UserAchievement[]
  gameSessions     GameSession[]
  refreshTokens    RefreshToken[]

  @@map("users")
}

model LearnerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  bio             String?
  interests       String[]
  learningGoals   String?  @map("learning_goals")
  preferredCategories CourseCategory[] @map("preferred_categories")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("learner_profiles")
}

model TeacherProfile {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  bio             String?
  coverImageUrl   String?   @map("cover_image_url")
  skills          String[]
  experience      Json?
  portfolio       Json?
  certifications  Json?
  introVideoUrl   String?   @map("intro_video_url")
  socialLinks     Json?     @map("social_links")
  ratingAvg       Float     @default(0) @map("rating_avg")
  reviewCount     Int       @default(0) @map("review_count")
  studentCount    Int       @default(0) @map("student_count")
  projectCount    Int       @default(0) @map("project_count")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("teacher_profiles")
}

model ClientProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  companyName String?  @map("company_name")
  industry    String?
  bio         String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model GamificationWallet {
  id             String    @id @default(uuid())
  userId         String    @unique @map("user_id")
  coins          Int       @default(0)
  xp             Int       @default(0)
  level          Int       @default(1)
  currentStreak  Int       @default(0) @map("current_streak")
  longestStreak  Int       @default(0) @map("longest_streak")
  lastLoginDate  DateTime? @map("last_login_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gamification_wallets")
}

model Course {
  id                String           @id @default(uuid())
  teacherId         String           @map("teacher_id")
  title             String
  slug              String           @unique
  description       String
  category          CourseCategory
  difficulty        Difficulty
  durationMinutes   Int              @map("duration_minutes")
  skills            String[]
  isFree            Boolean          @default(true) @map("is_free")
  priceCents        Int?             @map("price_cents")
  currency          String           @default("USD")
  thumbnailUrl      String?          @map("thumbnail_url")
  status            CourseStatus     @default(DRAFT)
  sourceType        CourseSourceType @default(UPLOADED) @map("source_type")
  externalUrl       String?          @map("external_url")
  youtubePlaylistId String?          @map("youtube_playlist_id")
  ratingAvg         Float            @default(0) @map("rating_avg")
  enrollmentCount   Int              @default(0) @map("enrollment_count")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  teacher     User           @relation(fields: [teacherId], references: [id])
  modules     CourseModule[]
  quizzes     Quiz[]
  enrollments Enrollment[]

  @@index([category, difficulty, status])
  @@map("courses")
}

model CourseModule {
  id        String   @id @default(uuid())
  courseId  String   @map("course_id")
  title     String
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("course_modules")
}

model Lesson {
  id              String   @id @default(uuid())
  moduleId        String   @map("module_id")
  title           String
  contentType     String   @map("content_type")
  contentUrl      String?  @map("content_url")
  durationMinutes Int      @default(0) @map("duration_minutes")
  sortOrder       Int      @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

model Quiz {
  id          String   @id @default(uuid())
  courseId    String   @map("course_id")
  title       String
  questions   Json
  passingScore Int     @default(70) @map("passing_score")
  coinReward  Int      @default(10) @map("coin_reward")
  createdAt   DateTime @default(now()) @map("created_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("quizzes")
}

model Enrollment {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  courseId        String    @map("course_id")
  progressPercent Float     @default(0) @map("progress_percent")
  lastLessonId    String?   @map("last_lesson_id")
  bookmarked      Boolean   @default(false)
  completedAt     DateTime? @map("completed_at")
  enrolledAt      DateTime  @default(now()) @map("enrolled_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model Service {
  id            String        @id @default(uuid())
  providerId    String        @map("provider_id")
  title         String
  category      CourseCategory
  description   String
  priceCents    Int           @map("price_cents")
  deliveryDays  Int           @map("delivery_days")
  faq           Json?
  portfolio     Json?
  status        ServiceStatus @default(DRAFT)
  ratingAvg     Float         @default(0) @map("rating_avg")
  reviewCount   Int           @default(0) @map("review_count")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  provider User @relation(fields: [providerId], references: [id])

  @@index([category, status])
  @@map("services")
}

model Booking {
  id              String        @id @default(uuid())
  bookingType     BookingType   @map("booking_type")
  requesterId     String        @map("requester_id")
  providerId      String        @map("provider_id")
  scheduledAt     DateTime      @map("scheduled_at")
  durationMinutes Int           @map("duration_minutes")
  capacity        Int           @default(1)
  status          BookingStatus @default(PENDING)
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  requester User @relation("BookingRequester", fields: [requesterId], references: [id])
  provider  User @relation("BookingProvider", fields: [providerId], references: [id])

  @@index([scheduledAt, status])
  @@map("bookings")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String?  @map("logo_url")
  website   String?
  createdAt DateTime @default(now()) @map("created_at")

  jobs JobPosting[]

  @@map("companies")
}

model JobPosting {
  id              String          @id @default(uuid())
  companyId       String          @map("company_id")
  title           String
  type            JobType
  category        CourseCategory
  location        String?
  remote          Boolean         @default(false)
  salaryMin       Int?            @map("salary_min")
  salaryMax       Int?            @map("salary_max")
  currency        String          @default("USD")
  experienceLevel ExperienceLevel @map("experience_level")
  description     String
  status          JobStatus       @default(OPEN)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  company      Company          @relation(fields: [companyId], references: [id])
  applications JobApplication[]

  @@map("job_postings")
}

model JobApplication {
  id          String   @id @default(uuid())
  jobId      String   @map("job_id")
  userId     String   @map("user_id")
  coverLetter String? @map("cover_letter")
  resumeUrl  String?  @map("resume_url")
  status     String   @default("PENDING")
  createdAt  DateTime @default(now()) @map("created_at")

  job  JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@map("job_applications")
}

model Review {
  id         String           @id @default(uuid())
  authorId   String           @map("author_id")
  targetType ReviewTargetType @map("target_type")
  targetId   String           @map("target_id")
  rating     Int
  comment    String?
  createdAt  DateTime         @default(now()) @map("created_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@map("reviews")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model Achievement {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  iconUrl     String?  @map("icon_url")
  coinReward  Int      @default(0) @map("coin_reward")
  xpReward    Int      @default(0) @map("xp_reward")
  createdAt   DateTime @default(now()) @map("created_at")

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  earnedAt      DateTime @default(now()) @map("earned_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model EducationalGame {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  category    CourseCategory
  coinReward  Int      @default(5) @map("coin_reward")
  xpReward    Int      @default(10) @map("xp_reward")
  config      Json?
  createdAt   DateTime @default(now()) @map("created_at")

  sessions GameSession[]

  @@map("educational_games")
}

model GameSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  gameId    String   @map("game_id")
  score     Int
  completed Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  game EducationalGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("game_sessions")
}

model AiUsageLog {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  date              DateTime @db.Date
  interactionsCount Int      @default(0) @map("interactions_count")
  coinsSpent        Int      @default(0) @map("coins_spent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("ai_usage_logs")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PlatformSettings {
  id                 String   @id @default("default")
  aiDailyLimit       Int      @default(5) @map("ai_daily_limit")
  platformCommission Float    @default(0.15) @map("platform_commission")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}
